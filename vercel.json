{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/toolkit", "destination": "/labkit", "permanent": true },
    { "source": "/toolkit/(.*)", "destination": "/labkit/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/" }
  ]
}
